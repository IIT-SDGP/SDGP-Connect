  PROJECT_DELETED
  PROJECT_APPROVED
  PROJECT_REJECTED
  PROJECT_FEATURED
  PROJECT_UNFEATURED
  AWARD_APPROVED
  AWARD_REJECTED
  COMPETITION_APPROVED
  COMPETITION_REJECTED
  BLOG_POST_APPROVED
  BLOG_POST_REJECTED
}

// ===================== NextAuth Adapter Models =====================
enum EmailOutboxStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

// Required by PrismaAdapter — do not rename fields.
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Required by PrismaAdapter for DB sessions (kept even if using JWT — adapter expects it).
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Required by PrismaAdapter for email verification flows.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===================== Application Models =====================

// Represents users of the platform.
// `id` is the NextAuth adapter-required primary key (renamed from user_id).
// `password` is nullable — only set for credential-based logins.
// `email` is required and unique — used as the identity anchor across providers.
model User {
  id               String            @id @default(uuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  image            String?
  password         String?           // nullable — only set for credentials logins
  role             Role              @default(STUDENT)

  // NextAuth adapter relations
  accounts         Account[]
  sessions         Session[]

  // Application relations
  approvedProjects ProjectStatus[]   @relation("ApprovedBy")
  featuredProjects ProjectMetadata[] @relation("FeaturedBy")
  ownedProjects    ProjectMetadata[] @relation("ProjectOwner")
  projectEditsCreated   ProjectEdit[] @relation("ProjectEditCreatedBy")
  projectEditsReviewed  ProjectEdit[] @relation("ProjectEditReviewedBy")
  acceptedAwards   Award[]           @relation("AcceptedAwards")
  rejectedAwards   Award[]           @relation("RejectedAwards")
  acceptedCompetitions Competition[] @relation("AcceptedCompetitions")
  rejectedCompetitions Competition[] @relation("RejectedCompetitions")
  approvedBlogPosts BlogPost[]       @relation("BlogPostsApprovedBy")
  rejectedBlogPosts BlogPost[]       @relation("BlogPostsRejectedBy")
  auditLogs        AuditLog[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([email])
}

// ===================== Project Models =====================

model EmailOutbox {
  id            String           @id @default(uuid())
  type          String
  to            String
  subject       String
  html          String           @db.LongText
  status        EmailOutboxStatus @default(PENDING)
  attempts      Int              @default(0)
  lastError     String?          @db.Text
  nextAttemptAt DateTime?
  meta          Json?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status, nextAttemptAt], name: "email_outbox_status_next_idx")
  @@index([createdAt], name: "email_outbox_created_idx")
}

// Stores the basic metadata of projects. Used for quick loading of project information without details.
model ProjectMetadata {
  project_id         String          @id @default(uuid())
  sdgp_year          String
  group_num          String
  title              String
  subtitle           String?
  website            String?
  cover_image        String?
  logo               String?
  featured           Boolean         @default(false)
  awards             Award[]         @relation("ProjectAwards")
  module             String?

  featured_by_userId String?
  featured_by        User?           @relation("FeaturedBy", fields: [featured_by_userId], references: [id], onDelete: SetNull)

  owner_userId String?
  owner        User?           @relation("ProjectOwner", fields: [owner_userId], references: [id], onDelete: SetNull)

  projectEdits ProjectEdit[] @relation("ProjectEditProject")

  projectContent     ProjectContent?

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([project_id], name: "project_id_index")
  @@index([featured_by_userId], name: "featured_by_index")
}

model ProjectEdit {
  id String @id @default(uuid())

  // The project this edit request applies to.
  project_id String
  project    ProjectMetadata @relation("ProjectEditProject", fields: [project_id], references: [project_id], onDelete: Cascade)

  // Student who submitted the edit request.
  created_by_userId String
  created_by        User   @relation("ProjectEditCreatedBy", fields: [created_by_userId], references: [id], onDelete: Cascade)

  status ProjectEditStatus @default(PENDING)

  // Admin/moderator who reviewed the edit.
  reviewed_by_userId String?
  reviewed_by        User?   @relation("ProjectEditReviewedBy", fields: [reviewed_by_userId], references: [id], onDelete: SetNull)

  reviewed_at      DateTime?
  rejected_reason  String?

  // For conflict detection: the live ProjectContent.content_id this draft was based on.
  base_content_id String?

  // Full proposed project snapshot (JSON) + list of computed changes (JSON).
  draft_snapshot Json
  changes        Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([project_id])
  @@index([created_by_userId])
  @@index([status])
}

model ProjectContent {
  content_id      String               @id @default(uuid())
  metadata_id     String               @unique
  metadata        ProjectMetadata      @relation(fields: [metadata_id], references: [project_id], onDelete: Restrict)
  projectDetails  ProjectDetails?
  status          ProjectStatus?       @relation("ProjectStatusToContent")
  associations    ProjectAssociation[]
  slides          ProjectSlide[]
  team            ProjectTeam[]
  socialLinks     ProjectSocialLink[]

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([metadata_id], map: "project_content_index")
}

model ProjectStatus {
  content_id         String                @id
  status             ProjectStatusEnum
  approved_status    ProjectApprovalStatus @default(PENDING)
  rejected_reason    String?
  approved_at        DateTime?

  approved_by_userId String?
  approved_by        User?                 @relation("ApprovedBy", fields: [approved_by_userId], references: [id], onDelete: SetNull)

  content            ProjectContent        @relation("ProjectStatusToContent", fields: [content_id], references: [content_id], onDelete: Restrict)

  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([approved_by_userId], name: "approved_by_index")
}

model ProjectAssociation {
  id          String            @id @default(uuid())
  content_id  String
  content     ProjectContent    @relation(fields: [content_id], references: [content_id], onDelete: Restrict)
  type        AssociationType
  value       String
  domain      ProjectDomainEnum?
  projectType ProjectTypeEnum?
  sdgGoal     SDGGoalEnum?
  techStack   TechStackEnum?
  award_id    String?
  award       Award?            @relation("AwardAssociation", fields: [award_id], references: [id], onDelete: SetNull)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([content_id], map: "project_association_index")
  @@index([award_id])
}

model ProjectSlide {
  id             String         @id @default(uuid())
  content_id     String
  content        ProjectContent @relation(fields: [content_id], references: [content_id], onDelete: Restrict)
  slides_content String

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([content_id], map: "project_slide_index")
}

model ProjectTeam {
  member_id     String         @id @default(uuid())
  content_id    String
  content       ProjectContent @relation(fields: [content_id], references: [content_id], onDelete: Restrict)
  name          String
  linkedin_url  String?
  profile_image String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([content_id], map: "project_team_index")
}

model ProjectSocialLink {
  id         String         @id @default(uuid())
  content_id String
  content    ProjectContent @relation(fields: [content_id], references: [content_id], onDelete: Restrict)
  link_name  SocialTypeEnum
  url        String

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([content_id], map: "project_social_index")
}

model ProjectDetails {
  id                String         @id @default(uuid())
  content_id        String         @unique
  content           ProjectContent @relation(fields: [content_id], references: [content_id], onDelete: Restrict)
  problem_statement String         @db.LongText
  solution          String         @db.LongText
  features          String         @db.LongText
  team_email        String
  team_phone        String

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([content_id], map: "project_details_index")
}

model Competition {
  id                  String         @id @default(uuid())
  name                String
  is_featured         Boolean        @default(false)
  start_date          DateTime
  end_date            DateTime
  description         String         @db.LongText
  type                String
  logo                String?
  cover_image         String?
  schools             String?
  module              String?
  teamsParticipated   Int?
  projectsCompleted   Int?
  approval_status     ApprovalStatus @default(PENDING)
  accepted_by_id      String?
  rejected_by_id      String?
  rejected_reason     String?

  accepted_by         User?          @relation("AcceptedCompetitions", fields: [accepted_by_id], references: [id], onDelete: SetNull)
  rejected_by         User?          @relation("RejectedCompetitions", fields: [rejected_by_id], references: [id], onDelete: SetNull)

  awards              Award[]

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([accepted_by_id])
  @@index([rejected_by_id])
}

model Award {
  id               String              @id @default(uuid())
  name             String
  image            String?
  competition_id   String
  competition      Competition         @relation(fields: [competition_id], references: [id], onDelete: Cascade)
  project_id       String
  project          ProjectMetadata     @relation("ProjectAwards", fields: [project_id], references: [project_id], onDelete: Cascade)
  associations     ProjectAssociation[] @relation("AwardAssociation")
  approval_status  ApprovalStatus      @default(PENDING)
  accepted_by_id   String?
  rejected_by_id   String?
  rejected_reason  String?

  accepted_by      User?               @relation("AcceptedAwards", fields: [accepted_by_id], references: [id], onDelete: SetNull)
  rejected_by      User?               @relation("RejectedAwards", fields: [rejected_by_id], references: [id], onDelete: SetNull)

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([competition_id])
  @@index([project_id])
  @@index([accepted_by_id])
  @@index([rejected_by_id])
}

model BlogPost {
  id             String            @id @default(uuid())
  title          String
  excerpt        String
  content        String            @db.LongText
  imageUrl       String?
  publishedAt    DateTime          @default(now())
  authorId       String
  author         BlogAuthor        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category       ProjectDomainEnum
  featured       Boolean           @default(false)
  approved       Boolean           @default(false)
  approvedById   String?
  approvedBy     User?             @relation("BlogPostsApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedById   String?
  rejectedBy     User?             @relation("BlogPostsRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedReason String?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  module         String?

  @@index([authorId])
  @@index([publishedAt])
  @@index([approvedById])
  @@index([rejectedById])
}

model BlogAuthor {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  avatarUrl  String?
  instagram  String?
  twitter    String?
  facebook   String?
  linkedin   String?
  medium     String?
  website    String?
  posts      BlogPost[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model AuditLog {
  id            String      @id @default(uuid())
  action        AuditAction
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType    String      // e.g., "PROJECT", "AWARD", "COMPETITION", "BLOG_POST"
  entityId      String      // The ID of the affected entity
  metadata      Json?       // Additional context (e.g., project title, group number, etc.)
  ipAddress     String?
  userAgent     String?

  createdAt     DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
