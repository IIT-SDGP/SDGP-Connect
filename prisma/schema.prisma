generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===================== Enums =====================

enum Role {
  ADMIN
  MODERATOR
  DEVELOPER
  STUDENT
}

enum AssociationType {
  PROJECT_TYPE
  PROJECT_DOMAIN
  PROJECT_SDG
  PROJECT_TECH
  AWARD
}

enum ProjectStatusEnum {
  IDEA
  MVP
  RESEARCH
  DEPLOYED
  STARTUP
}

