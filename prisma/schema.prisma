  AI
  ML
  AR_VR
  BLOCKCHAIN
  IOT
  HEALTHTECH
  FINTECH
  EDTECH
  AGRITECH
  ECOMMERCE
  SOCIAL
  GAMING
  SECURITY
  DATA_ANALYTICS
  ENTERTAINMENT
  SUSTAINABILITY
}

enum ProjectTypeEnum {
  MOBILE
  WEB
  HARDWARE
  DESKTOP
  WEARABLE
  EXTENSION
}

